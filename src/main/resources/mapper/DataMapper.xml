<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.java.gbizinfo.importer.mapper.DataMapper">
    <select id="getTimesCheckpointed" resultType="int">
        SELECT COUNT(*)
        FROM import_checkpoint
        WHERE zip_entry_name = #{entryName}
          AND run_id = #{runId}
    </select>
    <update id="copy">
        SELECT 1
    </update>
    <insert id="insertCheckpoint">
        INSERT INTO import_checkpoint (run_id, zip_entry_name)
        VALUES (#{runId}, #{entryName})
    </insert>
    <select id="getMaxPatentId" resultType="long">
        SELECT COALESCE(MAX(patent_id), 0)
        FROM patent
    </select>
    <select id="getMaxWorkplaceInfoId" resultType="long">
        SELECT COALESCE(MAX(workplace_info_id), 0)
        FROM workplace_info
    </select>
    <select id="getMaxFinanceId" resultType="long">
        SELECT COALESCE(MAX(finance_id), 0)
        FROM finance
    </select>
    <select id="getMaxCompanyId" resultType="long">
        SELECT COALESCE(MAX(company_id), 0)
        FROM company
    </select>
</mapper>